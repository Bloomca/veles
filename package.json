{
  "name": "veles",
  "version": "1.1.2",
  "description": "UI library with main focus on performance",
  "keywords": [
    "JavaScript",
    "UI",
    "library"
  ],
  "homepage": "https://github.com/Bloomca/veles#readme",
  "bugs": {
    "url": "https://github.com/Bloomca/veles/issues"
  },
  "license": "MIT",
  "author": "Seva Zaikov <mail@bloomca.me>",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/Bloomca/veles.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js",
      "require": "./dist/jsx-runtime.cjs"
    }
  },
  "scripts": {
    "test": "vitest run",
    "build": "tsdown",
    "ts-compile-check": "tsc -p tsconfig.json",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.1.0",
    "@testing-library/jest-dom": "^6.4.5",
    "@testing-library/user-event": "^14.5.2",
    "husky": "^9.1.7",
    "jsdom": "^24.0.0",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxfmt",
      "oxlint"
    ],
    "!(*-lock).json": "oxfmt",
    "*.{md,yml,yaml,css,html}": "oxfmt"
  }
}
